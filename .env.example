# Copy to .env and fill in values. Never commit .env.

# --- Database ---
# Async SQLAlchemy URL. asyncpg driver assumed.
# The bundled docker-compose maps Postgres to host port 5433 by default to
# avoid colliding with other local Postgres instances. Change here AND in
# OPENBOURSE_PG_HOST_PORT below if you need a different port.
OPENBOURSE_DATABASE_URL=postgresql+asyncpg://openbourse:openbourse@localhost:5433/openbourse

# Host port the docker-compose Postgres binds to. Container listens on 5432.
OPENBOURSE_PG_HOST_PORT=5433

# --- Fundamentals provider ---
# yfinance: free, unlimited, no key required, broad coverage including
#           ADRs and international tickers. Default.
# fmp:      Financial Modeling Prep — paid tiers offer better reliability
#           and bulk endpoints. Requires OPENBOURSE_FMP_API_KEY below.
# stub:     Fixture data from src/openbourse/data/seed.json. No network.
OPENBOURSE_FUNDAMENTALS_PROVIDER=yfinance

# --- Provider credentials (optional unless you switch providers) ---
# Financial Modeling Prep API key. Only needed when fundamentals_provider=fmp.
# https://financialmodelingprep.com/
OPENBOURSE_FMP_API_KEY=

# SEC EDGAR requires a descriptive User-Agent identifying the requester.
# https://www.sec.gov/os/accessing-edgar-data
OPENBOURSE_EDGAR_USER_AGENT=openbourse contact@example.com

# Anthropic Claude API key for AI briefs. https://console.anthropic.com/
OPENBOURSE_CLAUDE_API_KEY=
OPENBOURSE_CLAUDE_MODEL=claude-sonnet-4-6

# --- Runtime ---
# Master kill-switch. When true, every provider (including yfinance) is
# replaced by its stub. The test suite always sets this to true.
OPENBOURSE_USE_STUBS=false

# How often the screener polls the quote provider for fresh prices, in
# seconds. Set to 0 to disable polling entirely. Default 60s is friendly
# to free-tier rate limits; FMP paid plans can comfortably go to 5-15s.
OPENBOURSE_QUOTE_REFRESH_SECONDS=60

# Logging: DEBUG, INFO, WARNING, ERROR
OPENBOURSE_LOG_LEVEL=INFO

# --- Pre-market sync scheduler ---
# Used only by the docker-compose `scheduler` service
# (docker compose --profile scheduler up -d). Hour and minute, in US
# Eastern time, at which it runs `bourse universe sync` on weekdays.
# Default 09:00 ET — 30 minutes before the 09:30 market open. Anchored to
# America/New_York, so it stays correct across DST and host timezones.
OPENBOURSE_SYNC_HOUR=9
OPENBOURSE_SYNC_MINUTE=0
