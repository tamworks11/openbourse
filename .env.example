# Copy to .env and fill in values. Never commit .env.

# --- Database ---
# Async SQLAlchemy URL. asyncpg driver assumed.
OPENBOURSE_DATABASE_URL=postgresql+asyncpg://openbourse:openbourse@localhost:5432/openbourse

# --- Provider credentials (optional; stubs work without them) ---
# Financial Modeling Prep API key. https://financialmodelingprep.com/
OPENBOURSE_FMP_API_KEY=

# SEC EDGAR requires a descriptive User-Agent identifying the requester.
# https://www.sec.gov/os/accessing-edgar-data
OPENBOURSE_EDGAR_USER_AGENT=openbourse contact@example.com

# Anthropic Claude API key for AI briefs. https://console.anthropic.com/
OPENBOURSE_CLAUDE_API_KEY=
OPENBOURSE_CLAUDE_MODEL=claude-sonnet-4-6

# --- Runtime ---
# When true, providers return fixture data instead of calling external APIs.
OPENBOURSE_USE_STUBS=true

# Logging: DEBUG, INFO, WARNING, ERROR
OPENBOURSE_LOG_LEVEL=INFO
